{
  "name": "alex-evo-sh-ui-kit",
  "version": "1.1.90",
  "type": "module",
  "homepage": "https://alex-evo-2266.github.io/alex-evo-sh-ui-kit/",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy-storybook": "npm run build-storybook && ./node_modules/.bin/gh-pages -d storybook-static",
    "pub": "npm run build && npm version patch && npm publish"
  },
  "main": "./dist/alex-evo-sh-ui-kit.umd.js",
  "module": "./dist/alex-evo-sh-ui-kit.es.js",
  "types": "./dist/index.d.ts",
  "stylelint": {},
  "exports": {
    ".": {
      "import": "./dist/alex-evo-sh-ui-kit.es.js",
      "require": "./dist/alex-evo-sh-ui-kit.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*",
    "react-router-dom": "*"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.38.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "eslint-plugin-storybook": "^0.8.0",
    "gh-pages": "^6.1.1",
    "jsdom": "^27.3.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.8.2",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "storybook": "^10.2.19",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.2",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^3.9.1",
    "vite-plugin-lib-inject-css": "^2.1.0",
    "vitest": "^4.0.15"
  }
